# PostgreSQL connection string (Neon, Supabase, or Vercel Postgres)
# Use the pooled connection URL on serverless hosts (Vercel).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Public site URL for metadata and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Optional — raises GitHub API rate limit from 60 to 5,000 req/hr (public read is enough)
GITHUB_TOKEN=""

